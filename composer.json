{
    "name": "precision-soft/symfony-phpunit",
    "type": "library",
    "description": "Mockery-based mock container and test utilities for Symfony PHPUnit",
    "keywords": [
        "symfony",
        "phpunit",
        "mockery"
    ],
    "homepage": "https://github.com/precision-soft/symfony-phpunit",
    "license": "MIT",
    "authors": [
        {
            "name": "Adrian Jeledintan",
            "email": "adrian.jeledintan@precision-soft.com"
        }
    ],
    "require": {
        "php": ">=8.2",
        "mockery/mockery": "^1.0",
        "symfony/phpunit-bridge": "^7.0",
        "symfony/string": "^7.0"
    },
    "require-dev": {
        "doctrine/doctrine-bundle": "^2.0",
        "doctrine/orm": "^3.0",
        "friendsofphp/php-cs-fixer": "^3.0",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-mockery": "^2.0",
        "phpunit/phpunit": "^11.5",
        "symfony/framework-bundle": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "PrecisionSoft\\Symfony\\Phpunit\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PrecisionSoft\\Symfony\\Phpunit\\Test\\": "tests/"
        }
    },
    "scripts": {
        "install-hooks": [
            "[ \"${COMPOSER_DEV_MODE:-0}\" -eq 1 ] && rm -rf .git/hooks && ln -s ../.dev/git-hooks .git/hooks || exit 0"
        ],
        "post-install-cmd": [
            "@install-hooks"
        ],
        "post-update-cmd": [
            "@install-hooks"
        ]
    },
    "suggest": {
        "doctrine/orm": "Required to use ManagerRegistryMock",
        "doctrine/doctrine-bundle": "Required to use ManagerRegistryMock"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "audit": {
            "ignore": {
                "PKSA-5jz8-6tcw-pbk4": "Argument injection via newline in PHP INI forwarded to child processes (GHSA-qrr6-mg7r-m243). Dev-only dependency; no untrusted INI input in our test pipeline. Revisit once a patched 11.5.x is released or PHP floor is raised to 8.3 for PHPUnit ^12.5.22.",
                "PKSA-z3gr-8qht-p93v": "Unsafe deserialization in PHPT coverage (CVE-2026-24765); fixed in 11.5.50+. Kept in ignore list as belt-and-suspenders while pinned above 11.5.50."
            }
        }
    }
}
