#!/bin/bash

. "${PWD}/.dev/utility.sh"

stop() {
    if [[ "$2" != "" ]]; then
        error "$2"

        println ""
    fi

    section "stop pre commit hook"
    exit $1
}

check_container_dev() {
    if [[ $(check_container "${CONTAINER_DEV}") != 0 ]]; then
        println ""

        stop 1 "$(error_container ${CONTAINER_DEV})"
    fi
}

# ---------------------------------------------------------------------------------------------------------------------------------------------------------------------

lint() {
    STAGED_FILES=$1

    print_command "start php lint"
    println ""

    for FILE in ${STAGED_FILES}; do
        run_in_container_dev php -l -d display_errors=0 "${FILE}"

        if [[ $? != 0 ]]; then
            print_error "fix the error before commit"
            stop 1
        fi
    done

    println ""
    print_command "end php lint"
}

php_unit() {
    print_command "start php unit"
    println ""

    run_in_container_dev ./vendor/bin/simple-phpunit

    if [[ $? != 0 ]]; then
        print_error "fix the errors before commit"
        stop 1
    fi

    print_command "end php unit"
}

phpstan() {
    print_command "start phpstan"
    println ""

    run_in_container_dev php -d memory_limit=-1 ./vendor/bin/phpstan analyse --no-progress

    if [[ $? != 0 ]]; then
        print_error "fix the errors before commit"
        stop 1
    fi

    print_command "end phpstan"
}

php_cs_fixer() {
    print_command "start php cs fixer"
    println ""

    local files=()
    while IFS= read -r f; do
        [[ -n "$f" ]] && files+=("$f")
    done <<< "$1"

    run_in_container_dev ./vendor/bin/php-cs-fixer fix --config=.php-cs-fixer.dist.php "${files[@]}"

    if [[ $? != 0 ]]; then
        print_error "fix the errors before commit"
        stop 1
    fi

    while IFS= read -r FILE; do
        if [[ "${FILE}" != "" ]]; then
            git add "${FILE}"
        fi
    done < <(git diff --name-only -- '*.php')

    println ""
    print_command "end php cs fixer"
}

# ---------------------------------------------------------------------------------------------------------------------------------------------------------------------

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)

print_command "${PWD} start pre commit hook"

if [[ "${STAGED_FILES}" = "" ]]; then
    println "no files to commit"

    stop 0
fi

println ""

print_command "staged files start"
println "${STAGED_FILES}"
print_command "staged files end"

check_container_dev

STAGED_FILES_PHP=$(git diff --cached --name-only --diff-filter=ACMR HEAD | grep \\.php)
if [[ "${STAGED_FILES_PHP}" != "" ]]; then
    php_cs_fixer "${STAGED_FILES_PHP}"

    println ""

    lint "${STAGED_FILES_PHP}"

    println ""

    phpstan

    println ""

    php_unit
fi

println ""

print_command "staged files after hooks start"
println "$(git diff --cached --name-only)"
print_command "staged files after hooks end"

println ""

stop 0
